{
  "name": "meta_performance_adset_daily",
  "label": "Ad Set Daily Performance",
  "description": "Daily performance metrics at the ad set level",
  "category": "advertising",
  "source": {
    "type": "bigquery",
    "project": "datametricx-prod",
    "dataset": "reporting",
    "table": "meta_performance_adset_daily"
  },
  "primary_key": ["date", "adset_id"],

  "dimensions": [
    {
      "name": "tenant_id",
      "label": "Tenant ID",
      "type": "string",
      "description": "Tenant identifier",
      "sql": "${TABLE}.tenant_id",
      "hidden": true
    },
    {
      "name": "account_id",
      "label": "Account ID",
      "type": "string",
      "description": "Meta Ads account identifier",
      "sql": "${TABLE}.account_id"
    },
    {
      "name": "adset_id",
      "label": "Ad Set ID",
      "type": "string",
      "description": "Unique identifier for the ad set",
      "sql": "${TABLE}.adset_id",
      "primary_key": true
    },
    {
      "name": "adset_name",
      "label": "Ad Set Name",
      "type": "string",
      "description": "Name of the ad set",
      "sql": "${TABLE}.adset_name"
    },
    {
      "name": "campaign_id",
      "label": "Campaign ID",
      "type": "string",
      "description": "Parent campaign ID",
      "sql": "${TABLE}.campaign_id"
    },
    {
      "name": "campaign_name",
      "label": "Campaign Name",
      "type": "string",
      "description": "Name of the parent campaign",
      "sql": "${TABLE}.campaign_name"
    },
    {
      "name": "status",
      "label": "Status",
      "type": "string",
      "description": "Ad set status",
      "sql": "${TABLE}.status"
    }
  ],

  "dimension_groups": [
    {
      "name": "date",
      "label": "Date",
      "type": "time",
      "description": "Date of the metrics",
      "sql": "${TABLE}.date",
      "timeframes": ["raw", "time", "datetime", "date", "week", "month", "quarter", "year"],
      "datatype": "date"
    },
    {
      "name": "date_start",
      "label": "Report Start",
      "type": "time",
      "description": "Start date of the reporting period",
      "sql": "${TABLE}.date_start",
      "timeframes": ["raw", "time", "datetime", "date", "week", "month", "quarter", "year"],
      "datatype": "date"
    },
    {
      "name": "date_stop",
      "label": "Report End",
      "type": "time",
      "description": "End date of the reporting period",
      "sql": "${TABLE}.date_stop",
      "timeframes": ["raw", "time", "datetime", "date", "week", "month", "quarter", "year"],
      "datatype": "date"
    },
    {
      "name": "extracted_at",
      "label": "Extracted",
      "type": "time",
      "description": "When the data was extracted",
      "sql": "${TABLE}.extracted_at",
      "timeframes": ["raw", "time", "datetime", "date", "week", "month", "quarter", "year"],
      "datatype": "timestamp"
    },
    {
      "name": "_ingestion_time",
      "label": "Ingestion Time",
      "type": "time",
      "description": "When the data was ingested into BigQuery",
      "sql": "${TABLE}._ingestion_time",
      "timeframes": ["raw", "time", "datetime", "date", "week", "month", "quarter", "year"],
      "datatype": "timestamp"
    }
  ],

  "measures": [
    {
      "name": "impressions",
      "label": "Impressions",
      "type": "sum",
      "description": "Total number of times ads were shown",
      "sql": "${TABLE}.impressions",
      "value_format": "#,##0"
    },
    {
      "name": "clicks",
      "label": "Clicks",
      "type": "sum",
      "description": "Total number of clicks",
      "sql": "${TABLE}.clicks",
      "value_format": "#,##0"
    },
    {
      "name": "spend",
      "label": "Spend",
      "type": "sum",
      "description": "Total amount spent",
      "sql": "${TABLE}.spend",
      "value_format": "$#,##0.00"
    },
    {
      "name": "reach",
      "label": "Reach",
      "type": "sum",
      "description": "Number of unique people who saw ads",
      "sql": "${TABLE}.reach",
      "value_format": "#,##0"
    },
    {
      "name": "frequency",
      "label": "Frequency",
      "type": "average",
      "description": "Average number of times each person saw the ad",
      "sql": "${TABLE}.frequency",
      "value_format": "#,##0.00"
    },
    {
      "name": "actions",
      "label": "Actions",
      "type": "sum",
      "description": "Total number of actions taken",
      "sql": "${TABLE}.actions",
      "value_format": "#,##0"
    },
    {
      "name": "conversions",
      "label": "Conversions",
      "type": "sum",
      "description": "Total number of conversions",
      "sql": "${TABLE}.conversions",
      "value_format": "#,##0"
    },
    {
      "name": "conversions_value",
      "label": "Conversions Value",
      "type": "sum",
      "description": "Total value of conversions",
      "sql": "${TABLE}.conversions_value",
      "value_format": "$#,##0.00"
    },
    {
      "name": "count",
      "label": "Record Count",
      "type": "count",
      "description": "Number of records",
      "sql": "1",
      "value_format": "#,##0"
    }
  ],

  "calculations": [
    {
      "name": "ctr",
      "label": "CTR",
      "type": "number",
      "description": "Click-through rate (Clicks / Impressions)",
      "sql": "SAFE_DIVIDE(${clicks}, ${impressions}) * 100",
      "value_format": "#,##0.00'%'"
    },
    {
      "name": "cpc",
      "label": "CPC",
      "type": "number",
      "description": "Cost per click (Spend / Clicks)",
      "sql": "SAFE_DIVIDE(${spend}, ${clicks})",
      "value_format": "$#,##0.00"
    },
    {
      "name": "cpm",
      "label": "CPM",
      "type": "number",
      "description": "Cost per thousand impressions",
      "sql": "SAFE_DIVIDE(${spend}, ${impressions}) * 1000",
      "value_format": "$#,##0.00"
    },
    {
      "name": "cost_per_conversion",
      "label": "Cost per Conversion",
      "type": "number",
      "description": "Average cost per conversion",
      "sql": "SAFE_DIVIDE(${spend}, ${conversions})",
      "value_format": "$#,##0.00"
    },
    {
      "name": "roas",
      "label": "ROAS",
      "type": "number",
      "description": "Return on ad spend (Conversions Value / Spend)",
      "sql": "SAFE_DIVIDE(${conversions_value}, ${spend})",
      "value_format": "#,##0.00"
    },
    {
      "name": "conversion_rate",
      "label": "Conversion Rate",
      "type": "number",
      "description": "Percentage of clicks that converted",
      "sql": "SAFE_DIVIDE(${conversions}, ${clicks}) * 100",
      "value_format": "#,##0.00'%'"
    },
    {
      "name": "profit",
      "label": "Profit",
      "type": "number",
      "description": "Conversions Value minus Spend",
      "sql": "${conversions_value} - ${spend}",
      "value_format": "$#,##0.00"
    }
  ],

  "filters": [
    {
      "name": "date_range",
      "label": "Date Range",
      "type": "date",
      "field": "date"
    },
    {
      "name": "adset_filter",
      "label": "Ad Set",
      "type": "string",
      "field": "adset_name",
      "suggestions": true
    },
    {
      "name": "campaign_filter",
      "label": "Campaign",
      "type": "string",
      "field": "campaign_name",
      "suggestions": true
    },
    {
      "name": "status_filter",
      "label": "Status",
      "type": "string",
      "field": "status",
      "allowed_values": ["ACTIVE", "PAUSED", "ARCHIVED", "DELETED"]
    },
    {
      "name": "min_spend",
      "label": "Minimum Spend",
      "type": "number",
      "field": "spend",
      "operator": ">="
    }
  ]
}
